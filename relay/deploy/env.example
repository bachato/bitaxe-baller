# /etc/bitaxe-baller-relay.env
#
# Loaded by the systemd unit (EnvironmentFile=). Owned by root, mode 0600 —
# the RELAY_SECRET is the signing key for every session token, and rotating
# it invalidates every active session.
#
#     sudo chown root:root /etc/bitaxe-baller-relay.env
#     sudo chmod 0600       /etc/bitaxe-baller-relay.env

# REQUIRED. 32+ byte hex string. Generate with:
#     python3 -c "import secrets; print(secrets.token_hex(32))"
# Back this up — losing it kicks everyone out, regenerating to the same
# value is impossible. Treat like a password.
RELAY_SECRET=REPLACE_WITH_python3_-c_import_secrets_print_secrets_token_hex_32

# Bind interface + port. The systemd unit assumes 127.0.0.1:8787 behind
# nginx. If you change this, update both the unit and the nginx config.
RELAY_HOST=127.0.0.1
RELAY_PORT=8787

# License server. Default is the prod self-hosted endpoint. Override only
# if you're pointing at a staging license API.
# RELAY_LICENSE_API_BASE=https://bitaxeballer.com/api/license

# Session lifetime. Default 24h.
# RELAY_SESSION_TTL_S=86400

# Idle disconnect. App sockets that haven't seen client traffic in this
# many seconds get closed, so a forgotten remote tab can't chew bandwidth.
# RELAY_IDLE_DISCONNECT_S=3600

# Per-request timeout when forwarding to the app. The desktop app's own
# loopback HTTP timeout is 12s; this should be longer.
# RELAY_REQUEST_TIMEOUT_S=15.0

# Dev override — accepts a fixed key without hitting the license server.
# NEVER set in production.
# RELAY_DEV_LICENSE_KEY=
